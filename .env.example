# VFS Global Visa Automation Configuration
# Copy this file to .env and fill in your values

# ===== ACCOUNT CREDENTIALS =====
VFS_EMAIL=mustafa.eke@live.com
VFS_PASSWORD=Vfsglobal!5561!
VFS_PHONE=5468224662

# ===== IMAP CONFIGURATION =====
IMAP_EMAIL=mustafa.eke@live.com
IMAP_PASSWORD=AppPassword_Generated_In_Outlook
IMAP_SERVER=outlook.office365.com
IMAP_PORT=993

# ===== API CONFIGURATION =====
VFS_API_URL=https://lift-api.vfsglobal.com
API_TIMEOUT=30

# ===== CACHE CONFIGURATION =====
# 15 minutes in seconds
CACHE_DURATION_SEC=900

# ===== RETRY CONFIGURATION =====
MAX_RETRIES=3

# ===== LOGGING CONFIGURATION =====
LOG_LEVEL=INFO
LOG_DIR=/app/logs

# ===== BROWSER CONFIGURATION =====
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000

# ===== ACCOUNT LIMITS =====
MAX_CONCURRENT_ACCOUNTS=5
RATE_LIMIT_PER_ACCOUNT=5

# ===== PROXY CONFIGURATION =====
PROXY_ENABLED=false
PROXY_URL=

# ===== MULTI-ACCOUNT =====
MULTI_ACCOUNT_ENABLED=false
ACCOUNT_CONFIG_FILE=/app/data/accounts.json

# VFS Global Visa Automation Environment Configuration
# Copy from .env.example and fill in your values

# ===== ACCOUNT CREDENTIALS (Secrets) =====
VFS_EMAIL=mustafa.eke@live.com
VFS_PASSWORD=Vfsglobal!5561!
VFS_PHONE=5468224662

# ===== IMAP Configuration =====
IMAP_EMAIL=mustafa.eke@live.com
IMAP_PASSWORD=AppPassword_Generated_In_Outlook
IMAP_SERVER=outlook.office365.com
IMAP_PORT=993

# ===== API Configuration =====
VFS_API_URL=https://lift-api.vfsglobal.com
API_TIMEOUT=30

# ===== Cache Configuration (15 minutes) =====
CACHE_DURATION_SEC=900

# ===== Retry Configuration =====
MAX_RETRIES=3

# ===== Logging Configuration =====
LOG_LEVEL=INFO

# ===== Browser Configuration =====
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000

# ===== Account Limits =====
MAX_CONCURRENT_ACCOUNTS=5
RATE_LIMIT_PER_ACCOUNT=5

# ===== Proxy Configuration =====
PROXY_ENABLED=false
PROXY_URL=

# ===== Multi-Account =====
MULTI_ACCOUNT_ENABLED=false
ACCOUNT_CONFIG_FILE=/app/data/accounts.json

# ===== CloudFlare Specific =====
CLOUDFLARE_TOKENS_REFRESH=900
CLOUDFLARE_WAITING_ROOM_TIMEOUT=30

# ===== OTP Timing =====
OTP_POLL_INTERVAL_SEC=5
OTP_TIMEOUT_SEC=300

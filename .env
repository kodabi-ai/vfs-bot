VFS_EMAIL={{VFS_EMAIL}}
VFS_PASSWORD={{VFS_PASSWORD}}
VFS_PHONE={{VFS_PHONE}}

# OTP Credentials (Optional)
VFS_OTP_EMAIL={{VFS_EMAIL}}
VFS_OTP_PHONE={{VFS_PHONE}}

# RAG KB Configuration
RAG_KB_ENABLED=true
RAG_KB_PATH=/a0/usr/projects/kodabi-visa-automation/docs/

# Encryption
ENCRYPTION_KEY=vaultbox:35b:primary

# Browser Configuration
BROWSER_TYPE=playwright
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000

# OTP Configuration
OTP_POLL_INTERVAL=30
OTP_MAX_POLL_TIME=300
OTP_DUAL_CHANNEL=true

# Credential Rotation
CRED_ROTATION_INTERVAL_MINUTES=15
CRED_MAX_ACCOUNTS=10
CRED_ROTATION_STRATEGY=round_robin

# Docker Configuration
DOCKER_COMPOSE_FILE=docker-compose.production.yml
DOCKER_REPLICAS=3

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# CI/CD
GITHUB_TOKEN=github_token_placeholder
TELEGRAM_CHAT_ID=telegram_chat_id_placeholder
TELEGRAM_TOKEN=telegram_bot_token_placeholder
